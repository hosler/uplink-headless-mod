<LoginScreen>:
    handle_input: handle_input
    password_input: password_input

    GradientBg:
        size: root.size
        pos: root.pos

    # Centered login panel
    BoxLayout:
        orientation: 'vertical'
        size_hint: (0.35, None)
        height: dp(380)
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        spacing: dp(12)
        padding: [dp(30), dp(20)]

        # Title
        Label:
            text: 'U P L I N K'
            font_name: 'AeroMatics'
            font_size: sp(40)
            color: app.c_primary
            size_hint_y: None
            height: dp(54)

        Label:
            text: 'HEADLESS MULTIPLAYER SERVER'
            font_name: 'AeroMaticsLight'
            font_size: sp(14)
            color: app.c_secondary
            size_hint_y: None
            height: dp(24)

        # Spacer
        Widget:
            size_hint_y: None
            height: dp(20)

        # Handle
        Label:
            text: 'AGENT HANDLE'
            font_name: 'AeroMatics'
            font_size: sp(15)
            color: app.c_secondary
            halign: 'left'
            text_size: self.size
            size_hint_y: None
            height: dp(22)

        HackerTextInput:
            id: handle_input
            hint_text: 'Enter handle...'
            hint_text_color: (0.25, 0.45, 0.65, 1)
            size_hint_y: None
            height: dp(42)
            on_text_validate: root.do_join()

        # Password
        Label:
            text: 'PASSWORD'
            font_name: 'AeroMatics'
            font_size: sp(15)
            color: app.c_secondary
            halign: 'left'
            text_size: self.size
            size_hint_y: None
            height: dp(22)

        HackerTextInput:
            id: password_input
            hint_text: 'Enter password...'
            hint_text_color: (0.25, 0.45, 0.65, 1)
            password: True
            size_hint_y: None
            height: dp(42)
            on_text_validate: root.do_join()

        # Spacer
        Widget:
            size_hint_y: None
            height: dp(10)

        # Connect button
        HackerButton:
            text: 'CONNECT'
            size_hint_y: None
            height: dp(44)
            font_size: sp(18)
            on_release: root.do_join()

        # Error label
        Label:
            text: root.error_text
            font_name: 'AeroMatics'
            font_size: sp(14)
            color: app.c_alert
            size_hint_y: None
            height: dp(24)
